<% flash.each do |type, message| %>
  <div data-controller="toast" 
       class="toast show align-items-center border-0 mb-2 shadow <%= (type == 'notice') ? 'text-bg-success' : 'text-bg-warning' %>" 
       role="alert">
    <div class="d-flex">
      <div class="toast-body">
        <%= message %>
      </div>
      <button type="button" 
              class="btn-close btn-close-white me-2 m-auto" 
              data-action="click->toast#close">
    </button>
    </div>
  </div>
<% end %>